# ─── xAI / Grok ────────────────────────────────────────────────────────────────
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
MODEL_NAME=grok-4-1

# ─── Pipeline ──────────────────────────────────────────────────────────────────
MAX_CONCURRENCY=5
MAX_LLM_RETRIES=3
LLM_RETRY_MIN_WAIT=1
LLM_RETRY_MAX_WAIT=10

# ─── Storage ───────────────────────────────────────────────────────────────────
CACHE_DIR=./cache
UPLOAD_DIR=./uploads
LOG_LEVEL=INFO

# ─── App ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
